# EVM block explorers (Etherscan-family)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISM_API_KEY=

# Tronscan
TRONSCAN_API_KEY=

# Fireblocks — FIREBLOCKS_SECRET_KEY may be the raw PEM contents or a path to the .pem file
FIREBLOCKS_API_KEY=
FIREBLOCKS_SECRET_KEY=
FIREBLOCKS_BASE_URL=https://api.fireblocks.io

# Google Sheets — path to the service-account credentials JSON file
GOOGLE_SHEETS_CREDENTIALS_FILE=src/core/sheets.json
