# EVM block explorers (Etherscan-family)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISM_API_KEY=

# Tronscan
TRONSCAN_API_KEY=

# Fireblocks — FIREBLOCKS_SECRET_KEY may be the raw PEM contents or a path to the .pem file
FIREBLOCKS_API_KEY=
FIREBLOCKS_SECRET_KEY_PATH=
FIREBLOCKS_BASE_URL=https://api.fireblocks.io

# Google Sheets — path to the service-account credentials JSON file
GOOGLE_SHEETS_CREDENTIALS_FILE=src/core/sheets.json
OTC_SPREADSHEET_URL=
OTC_TAB_BALANCE=Balance
OTC_TAB_CLIENT_BALANCE=Client Balance

# Internal loan snapshot
INTERNAL_LOAN_SPREADSHEET_URL=
INTERNAL_LOAN_TAB_SUMMARY=Summary

# Balance ingest spreadsheet (ClientBalance + BalanceIDR tabs)
BALANCE_INGEST_SPREADSHEET_URL=
BALANCE_INGEST_TAB_CLIENT=ClientBalance
BALANCE_INGEST_TAB_IDR_BANK=BalanceIDR

# ClickHouse — set CLICKHOUSE_URL directly, or fill in the parts below
CLICKHOUSE_URL=
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_POOL_SIZE=2
CLICKHOUSE_MAX_OVERFLOW=5
CLICKHOUSE_POOL_TIMEOUT=30
CLICKHOUSE_POOL_RECYCLE=900
