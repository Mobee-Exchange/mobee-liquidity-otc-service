# EVM block explorers (Etherscan-family)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISM_API_KEY=

# Tronscan
TRONSCAN_API_KEY=

# Binance — separate API keys for the main and sub accounts
BINANCE_MAIN_API_KEY=
BINANCE_MAIN_SECRET=
BINANCE_SUB_API_KEY=
BINANCE_SUB_SECRET=

# Gate.io — separate API keys for the main and sub accounts
GATE_MAIN_API_KEY=
GATE_MAIN_SECRET=
GATE_SUB_API_KEY=
GATE_SUB_SECRET=

# Fireblocks — FIREBLOCKS_SECRET_KEY may be the raw PEM contents or a path to the .pem file
FIREBLOCKS_API_KEY=
FIREBLOCKS_SECRET_KEY=
FIREBLOCKS_BASE_URL=https://api.fireblocks.io

# Google Sheets — path to the service-account credentials JSON file
GOOGLE_SHEETS_CREDENTIALS_FILE=src/core/sheets.json

# Balance ingest spreadsheet (ClientBalance + BalanceIDR tabs)
BALANCE_INGEST_SPREADSHEET_URL=
BALANCE_INGEST_TAB_CLIENT=ClientBalance
BALANCE_INGEST_TAB_IDR_BANK=BalanceIDR

# Database connection URLs (full SQLAlchemy URLs)
# e.g. clickhouse+http://user:pass@host:8123/database
CLICKHOUSE_URL=
# e.g. postgresql+psycopg2://user:pass@host:5432/database
POSTGRES_URL=

# Shared connection-pool tuning (applies to all databases; optional, has defaults)
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=900
